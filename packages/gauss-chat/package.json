{
  "name": "@gauss-ai/chat",
  "version": "2.13.0",
  "description": "React hooks for building AI chat interfaces with Gauss — useChat, useCompletion, useAgent",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "server": [
        "dist/server.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^26.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.1.2",
    "tsup": "^8.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "keywords": [
    "gauss",
    "ai",
    "chat",
    "hooks",
    "react",
    "streaming",
    "useChat",
    "useCompletion",
    "useAgent",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/giulio-leone/gauss.git",
    "directory": "packages/gauss-chat"
  },
  "author": "Giulio Leone <https://github.com/giulio-leone>",
  "publishConfig": {
    "access": "public"
  }
}
